{% block extra_js %}
<script>
(function() {
    const hash = window.location.hash;
    if (hash) {
        const trigger = document.querySelector(`[data-bs-target="${hash}"]`);
        if (trigger) bootstrap.Tab.getOrCreateInstance(trigger).show();
    }
    document.querySelectorAll('[data-check-all]').forEach(function(master){
        master.addEventListener('change', function(){
            const table = document.querySelector(master.dataset.checkAll);
            if (!table) return;
            table.querySelectorAll('tbody input[type="checkbox"][name="ids"]').forEach(cb => cb.checked = master.checked);
        });
    });

    const canEdit = {{ can_edit_rdc|yesno:'true,false' }};
    if (!canEdit) return;

    function csrfToken(){ return document.querySelector('[name=csrfmiddlewaretoken]')?.value || ''; }
    function createEditor(cell, oldText) {
        const field = cell.dataset.field;
        if (['comentarios', 'observacao', 'mensagem', 'referencia'].includes(field)) {
            const textarea = document.createElement('textarea');
            textarea.className = 'form-control form-control-sm';
            textarea.rows = 3;
            textarea.value = oldText;
            return textarea;
        }
        if (['ativa_no_dia', 'presente_catraca', 'confirmado_supervisor'].includes(field)) {
            const select = document.createElement('select');
            select.className = 'form-select form-select-sm';
            [['true','Sim'],['false','Não']].forEach(([val,label]) => {
                const opt = document.createElement('option');
                opt.value = val;
                opt.textContent = label;
                if ((oldText || '').toLowerCase() === label.toLowerCase()) opt.selected = true;
                select.appendChild(opt);
            });
            return select;
        }
        if (field === 'status') {
            const select = document.createElement('select');
            select.className = 'form-select form-select-sm';
            [['info','Info'],['alerta','Alerta'],['bloqueio','Bloqueio']].forEach(([val,label]) => {
                const opt = document.createElement('option');
                opt.value = val;
                opt.textContent = label;
                if ((oldText || '').toLowerCase() === val) opt.selected = true;
                select.appendChild(opt);
            });
            return select;
        }
        const input = document.createElement('input');
        input.className = 'form-control form-control-sm';
        input.value = oldText;
        return input;
    }

    document.querySelectorAll('.inline-editable').forEach(cell => {
        cell.addEventListener('dblclick', async () => {
            if (cell.querySelector('input,textarea,select')) return;
            const oldText = cell.innerText.trim() === '-' ? '' : cell.innerText.trim();
            const editor = createEditor(cell, oldText);
            cell.dataset.old = cell.innerHTML;
            cell.innerHTML = '';
            cell.appendChild(editor);
            editor.focus();

            const restore = () => { cell.innerHTML = cell.dataset.old; };
            editor.addEventListener('keydown', ev => {
                if (ev.key === 'Escape') restore();
                if (ev.key === 'Enter' && editor.tagName !== 'TEXTAREA') editor.blur();
            });
            editor.addEventListener('blur', async () => {
                const newValue = editor.value;
                if (newValue === oldText) { restore(); return; }
                cell.classList.add('inline-saving');
                
                const body = new URLSearchParams({field: cell.dataset.field, value: newValue});
                const resp = await fetch(url, {method:'POST', headers:{'X-CSRFToken': csrfToken(), 'Content-Type':'application/x-www-form-urlencoded'}, body});
                const data = await resp.json();
                cell.classList.remove('inline-saving');
                if (data.ok){
                    cell.textContent = data.display || newValue || '-';
                    cell.classList.add('inline-saved');
                    setTimeout(() => cell.classList.remove('inline-saved'), 1200);
                    if (data.hh_total) {
                        const hhCell = document.querySelector(`.hh-cell[data-id="${cell.dataset.id}"]`);
                        if (hhCell) hhCell.textContent = data.hh_total;
                    }
                }
                else { alert(data.message || 'Não foi possível atualizar.'); restore(); }
            });
        });
    });
})();
</script>
{% endblock %}










