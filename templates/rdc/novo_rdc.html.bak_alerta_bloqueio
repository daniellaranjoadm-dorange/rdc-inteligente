}
.filter-chip {
  display:inline-flex; align-items:center; gap:.45rem; padding:.55rem .8rem; border-radius:999px;
  background:#eff6ff; border:1px solid #bfdbfe; color:#1d4ed8; text-decoration:none; font-weight:700; font-size:.85rem;
