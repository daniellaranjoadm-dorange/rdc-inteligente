import 'package:flutter/material.dart';

import '../../data/services/rdc_detail_service.dart';
import '../../data/services/rdc_update_service.dart';

class RdcDetailPage extends StatefulWidget {
  final int rdcId;

  const RdcDetailPage({
    super.key,
    required this.rdcId,
  });

  @override
  State<RdcDetailPage> createState() => _RdcDetailPageState();
}

class _RdcDetailPageState extends State<RdcDetailPage> {
  final _updateService = RdcUpdateService();
  final _observacoesController = TextEditingController();
  final _horarioInicioController = TextEditingController();
  final _horarioFimController = TextEditingController();

  bool _isEditing = false;
  bool _isSaving = false;
  bool _initialized = false;

  String? _turno;
  String? _condicaoArea;
  String? _climaManha;
  String? _climaTarde;
  String? _climaNoite;

  @override
  void dispose() {
    _observacoesController.dispose();
    _horarioInicioController.dispose();
    _horarioFimController.dispose();
    super.dispose();
  }

  String _displayField(dynamic value, {String fallback = '-'}) {
    if (value == null) return fallback;
    final text = value.toString().trim();
    return text.isEmpty ? fallback : text;
  }

  String _displayNested(Map<String, dynamic>? map, List<String> keys) {
    if (map == null) return '-';
    for (final key in keys) {
      final value = map[key];
      if (value != null && value.toString().trim().isNotEmpty) {
        return value.toString().trim();
      }
    }
    return '-';
  }

  void _fillForm(Map<String, dynamic> data) {
    if (_initialized) return;
    _initialized = true;

    _turno = data['turno']?.toString();
    _condicaoArea = data['condicao_area']?.toString();
    _climaManha = data['clima_manha']?.toString();
    _climaTarde = data['clima_tarde']?.toString();
    _climaNoite = data['clima_noite']?.toString();

    _observacoesController.text = (data['observacoes'] ?? '').toString();
    _horarioInicioController.text = (data['horario_inicio'] ?? '').toString();
    _horarioFimController.text = (data['horario_fim'] ?? '').toString();
  }

  Future<void> _save() async {
    setState(() {
      _isSaving = true;
    });

    final payload = <String, dynamic>{
      'turno': _turno,
      'condicao_area': _emptyToNull(_condicaoArea),
      'clima_manha': _emptyToNull(_climaManha),
      'clima_tarde': _emptyToNull(_climaTarde),
      'clima_noite': _emptyToNull(_climaNoite),
      'horario_inicio': _emptyToNull(_horarioInicioController.text),
      'horario_fim': _emptyToNull(_horarioFimController.text),
      'observacoes': _observacoesController.text.trim(),
    };

    final result = await _updateService.updateRdc(
      rdcId: widget.rdcId,
      payload: payload,
    );

    if (!mounted) return;

    setState(() {
      _isSaving = false;
    });

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text(result.message)),
    );

    if (result.success) {
      setState(() {
        _isEditing = false;
      });
    }
  }

  String? _emptyToNull(String? value) {
    if (value == null) return null;
    final text = value.trim();
    return text.isEmpty ? null : text;
  }

  @override
  Widget build(BuildContext context) {
    final service = RdcDetailService();

    return Scaffold(
      appBar: AppBar(
        title: Text('RDC #${widget.rdcId}'),
        actions: [
          IconButton(
            tooltip: _isEditing ? 'Cancelar edição' : 'Editar',
            onPressed: _isSaving
                ? null
                : () {
                    setState(() {
                      _isEditing = !_isEditing;
                    });
                  },
            icon: Icon(_isEditing ? Icons.close : Icons.edit),
          ),
        ],
      ),
      body: SafeArea(
        child: FutureBuilder<RdcDetailResult>(
          future: service.getDetail(widget.rdcId),
          builder: (context, snapshot) {
            if (snapshot.connectionState != ConnectionState.done) {
              return const Center(child: CircularProgressIndicator());
            }

            final result = snapshot.data;

            if (result == null || !result.success || result.data == null) {
              return Center(
                child: Padding(
                  padding: const EdgeInsets.all(24),
                  child: Text(
                    result?.message ?? 'Não foi possível carregar o RDC.',
                    style: const TextStyle(
                      color: Colors.redAccent,
                      fontSize: 16,
                    ),
                  ),
                ),
              );
            }

            final data = result.data!;
            _fillForm(data);

            final projeto = data['projeto'] as Map<String, dynamic>?;
            final disciplina = data['disciplina'] as Map<String, dynamic>?;
            final areaLocal = data['area_local'] as Map<String, dynamic>?;
            final supervisor = data['supervisor'] as Map<String, dynamic>?;

            final funcionarios = (data['funcionarios'] as List?) ?? const [];
            final atividades = (data['atividades'] as List?) ?? const [];
            final apontamentos = (data['apontamentos'] as List?) ?? const [];

            return SingleChildScrollView(
              padding: const EdgeInsets.all(20),
              child: Center(
                child: ConstrainedBox(
                  constraints: const BoxConstraints(maxWidth: 1200),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      const Text(
                        'Detalhe do RDC',
                        style: TextStyle(
                          fontSize: 28,
                          fontWeight: FontWeight.bold,
                        ),
                      ),
                      const SizedBox(height: 8),
                      Text(
                        'RDC #${_displayField(data['id'])}',
                        style: const TextStyle(
                          fontSize: 16,
                          color: Colors.grey,
                        ),
                      ),
                      const SizedBox(height: 20),
                      Wrap(
                        spacing: 16,
                        runSpacing: 16,
                        children: [
                          _InfoCard(
                            title: 'Projeto',
                            value: _displayNested(projeto, ['codigo', 'nome']),
                            subtitle: projeto == null
                                ? '-'
                                : '${_displayField(projeto['codigo'])} - ${_displayField(projeto['nome'])}',
                          ),
                          _InfoCard(
                            title: 'Disciplina',
                            value: _displayNested(disciplina, ['nome']),
                            subtitle: _displayField(disciplina?['codigo'], fallback: ''),
                          ),
                          _InfoCard(
                            title: 'Área local',
                            value: _displayNested(areaLocal, ['descricao', 'nome']),
                            subtitle: areaLocal == null
                                ? '-'
                                : '${_displayField(areaLocal['codigo'])} - ${_displayField(areaLocal['descricao'])}',
                          ),
                          _InfoCard(
                            title: 'Turno',
                            value: _displayField(_turno ?? data['turno']),
                            subtitle: 'Data: ${_displayField(data['data'])}',
                          ),
                          _InfoCard(
                            title: 'Status',
                            value: _displayField(data['status']),
                            subtitle: 'Dia: ${_displayField(data['dia_semana'])}',
                          ),
                          _InfoCard(
                            title: 'Supervisor',
                            value: _displayNested(supervisor, ['nome', 'username']),
                            subtitle: _displayField(supervisor?['matricula'], fallback: ''),
                          ),
                        ],
                      ),
                      const SizedBox(height: 24),
                      Card(
                        child: Padding(
                          padding: const EdgeInsets.all(20),
                          child: Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              Row(
                                children: [
                                  const Text(
                                    'Dados gerais',
                                    style: TextStyle(
                                      fontSize: 20,
                                      fontWeight: FontWeight.bold,
                                    ),
                                  ),
                                  const Spacer(),
                                  if (_isEditing)
                                    ElevatedButton(
                                      onPressed: _isSaving ? null : _save,
                                      child: _isSaving
                                          ? const SizedBox(
                                              height: 20,
                                              width: 20,
                                              child: CircularProgressIndicator(
                                                strokeWidth: 2.2,
                                              ),
                                            )
                                          : const Text('Salvar alterações'),
                                    ),
                                ],
                              ),
                              const SizedBox(height: 16),
                              if (_isEditing) ...[
                                DropdownButtonFormField<String>(
                                  value: _turno,
                                  decoration: const InputDecoration(
                                    labelText: 'Turno',
                                  ),
                                  items: const [
                                    DropdownMenuItem(value: 'manha', child: Text('Manhã')),
                                    DropdownMenuItem(value: 'tarde', child: Text('Tarde')),
                                    DropdownMenuItem(value: 'noite', child: Text('Noite')),
                                    DropdownMenuItem(value: 'integral', child: Text('Integral')),
                                  ],
                                  onChanged: (value) {
                                    setState(() {
                                      _turno = value;
                                    });
                                  },
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  initialValue: _condicaoArea ?? '',
                                  decoration: const InputDecoration(
                                    labelText: 'Condição da área',
                                  ),
                                  onChanged: (value) => _condicaoArea = value,
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  initialValue: _climaManha ?? '',
                                  decoration: const InputDecoration(
                                    labelText: 'Clima manhã',
                                  ),
                                  onChanged: (value) => _climaManha = value,
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  initialValue: _climaTarde ?? '',
                                  decoration: const InputDecoration(
                                    labelText: 'Clima tarde',
                                  ),
                                  onChanged: (value) => _climaTarde = value,
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  initialValue: _climaNoite ?? '',
                                  decoration: const InputDecoration(
                                    labelText: 'Clima noite',
                                  ),
                                  onChanged: (value) => _climaNoite = value,
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  controller: _horarioInicioController,
                                  decoration: const InputDecoration(
                                    labelText: 'Horário início',
                                  ),
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  controller: _horarioFimController,
                                  decoration: const InputDecoration(
                                    labelText: 'Horário fim',
                                  ),
                                ),
                                const SizedBox(height: 12),
                                TextFormField(
                                  controller: _observacoesController,
                                  minLines: 3,
                                  maxLines: 5,
                                  decoration: const InputDecoration(
                                    labelText: 'Observações',
                                    alignLabelWithHint: true,
                                  ),
                                ),
                              ] else ...[
                                Wrap(
                                  spacing: 24,
                                  runSpacing: 12,
                                  children: [
                                    _FieldText(label: 'Condição da área', value: _displayField(data['condicao_area'])),
                                    _FieldText(label: 'Clima manhã', value: _displayField(data['clima_manha'])),
                                    _FieldText(label: 'Clima tarde', value: _displayField(data['clima_tarde'])),
                                    _FieldText(label: 'Clima noite', value: _displayField(data['clima_noite'])),
                                    _FieldText(label: 'Horário início', value: _displayField(data['horario_inicio'])),
                                    _FieldText(label: 'Horário fim', value: _displayField(data['horario_fim'])),
                                  ],
                                ),
                                const SizedBox(height: 16),
                                _FieldText(
                                  label: 'Observações',
                                  value: _displayField(data['observacoes']),
                                ),
                              ],
                            ],
                          ),
                        ),
                      ),
                      const SizedBox(height: 24),
                      Wrap(
                        spacing: 16,
                        runSpacing: 16,
                        children: [
                          _SummaryCard(
                            title: 'Funcionários',
                            value: funcionarios.length.toString(),
                            icon: Icons.groups_outlined,
                          ),
                          _SummaryCard(
                            title: 'Atividades',
                            value: atividades.length.toString(),
                            icon: Icons.assignment_outlined,
                          ),
                          _SummaryCard(
                            title: 'Apontamentos',
                            value: apontamentos.length.toString(),
                            icon: Icons.schedule_outlined,
                          ),
                        ],
                      ),
                      const SizedBox(height: 24),
                      _SectionCard(
                        title: 'Funcionários',
                        emptyMessage: 'Nenhum funcionário lançado neste RDC.',
                        items: funcionarios,
                        itemBuilder: (item) {
                          final map = Map<String, dynamic>.from(item as Map);
                          return _SimpleListTile(
                            title: _displayField(map['nome']),
                            subtitle: [
                              _displayField(map['matricula'], fallback: ''),
                              _displayField(map['funcao_nome'], fallback: ''),
                            ].where((e) => e.isNotEmpty).join(' • '),
                          );
                        },
                      ),
                      const SizedBox(height: 16),
                      _SectionCard(
                        title: 'Atividades',
                        emptyMessage: 'Nenhuma atividade lançada neste RDC.',
                        items: atividades,
                        itemBuilder: (item) {
                          final map = Map<String, dynamic>.from(item as Map);
                          return _SimpleListTile(
                            title: _displayField(map['descricao']),
                            subtitle: [
                              _displayField(map['codigo_atividade'], fallback: ''),
                              _displayField(map['codigo_subatividade'], fallback: ''),
                            ].where((e) => e.isNotEmpty).join(' • '),
                          );
                        },
                      ),
                      const SizedBox(height: 16),
                      _SectionCard(
                        title: 'Apontamentos',
                        emptyMessage: 'Nenhum apontamento lançado neste RDC.',
                        items: apontamentos,
                        itemBuilder: (item) {
                          final map = Map<String, dynamic>.from(item as Map);
                          return _SimpleListTile(
                            title: _displayField(map['descricao']),
                            subtitle: _displayField(map['quantidade']),
                          );
                        },
                      ),
                    ],
                  ),
                ),
              ),
            );
          },
        ),
      ),
    );
  }
}

class _InfoCard extends StatelessWidget {
  final String title;
  final String value;
  final String subtitle;

  const _InfoCard({
    required this.title,
    required this.value,
    required this.subtitle,
  });

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      width: 280,
      child: Card(
        child: Padding(
          padding: const EdgeInsets.all(18),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Text(title, style: const TextStyle(fontSize: 14, color: Colors.grey)),
              const SizedBox(height: 8),
              Text(
                value,
                style: const TextStyle(fontSize: 20, fontWeight: FontWeight.w700),
              ),
              if (subtitle.trim().isNotEmpty) ...[
                const SizedBox(height: 6),
                Text(
                  subtitle,
                  style: const TextStyle(fontSize: 13, color: Colors.grey),
                ),
              ],
            ],
          ),
        ),
      ),
    );
  }
}

class _SummaryCard extends StatelessWidget {
  final String title;
  final String value;
  final IconData icon;

  const _SummaryCard({
    required this.title,
    required this.value,
    required this.icon,
  });

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      width: 240,
      child: Card(
        child: Padding(
          padding: const EdgeInsets.all(18),
          child: Row(
            children: [
              Icon(icon, size: 34, color: Theme.of(context).colorScheme.primary),
              const SizedBox(width: 14),
              Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    value,
                    style: const TextStyle(fontSize: 26, fontWeight: FontWeight.bold),
                  ),
                  Text(title, style: const TextStyle(color: Colors.grey)),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }
}

class _FieldText extends StatelessWidget {
  final String label;
  final String value;

  const _FieldText({
    required this.label,
    required this.value,
  });

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      width: 220,
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Text(label, style: const TextStyle(fontSize: 13, color: Colors.grey)),
          const SizedBox(height: 4),
          Text(
            value,
            style: const TextStyle(fontSize: 16, fontWeight: FontWeight.w500),
          ),
        ],
      ),
    );
  }
}

class _SectionCard extends StatelessWidget {
  final String title;
  final String emptyMessage;
  final List items;
  final Widget Function(dynamic item) itemBuilder;

  const _SectionCard({
    required this.title,
    required this.emptyMessage,
    required this.items,
    required this.itemBuilder,
  });

  @override
  Widget build(BuildContext context) {
    return Card(
      child: Padding(
        padding: const EdgeInsets.all(20),
        child: items.isEmpty
            ? Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    title,
                    style: const TextStyle(fontSize: 20, fontWeight: FontWeight.bold),
                  ),
                  const SizedBox(height: 12),
                  Text(emptyMessage, style: const TextStyle(color: Colors.grey)),
                ],
              )
            : Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: [
                  Text(
                    '$title (${items.length})',
                    style: const TextStyle(fontSize: 20, fontWeight: FontWeight.bold),
                  ),
                  const SizedBox(height: 12),
                  ...items.map(
                    (item) => Padding(
                      padding: const EdgeInsets.only(bottom: 10),
                      child: itemBuilder(item),
                    ),
                  ),
                ],
              ),
      ),
    );
  }
}

class _SimpleListTile extends StatelessWidget {
  final String title;
  final String subtitle;

  const _SimpleListTile({
    required this.title,
    required this.subtitle,
  });

  @override
  Widget build(BuildContext context) {
    return Container(
      decoration: BoxDecoration(
        border: Border.all(color: const Color(0xFFE5E7EB)),
        borderRadius: BorderRadius.circular(12),
      ),
      child: ListTile(
        title: Text(title),
        subtitle: subtitle.trim().isEmpty ? null : Text(subtitle),
      ),
    );
  }
}
