  Widget _buildMainForm({
    required double width,
    required Map<String, dynamic> data,
    required Map<String, dynamic>? projeto,
    required Map<String, dynamic>? areaLocal,
    required Map<String, dynamic>? disciplina,
    required Map<String, dynamic>? supervisor,
    required List<Map<String, dynamic>> funcionarios,
    required List<Map<String, dynamic>> atividades,
    required List<Map<String, dynamic>> apontamentos,
  }) {
    final phone = _isPhone(width);
    final cols = phone ? 1 : 2;

    return Column(
      children: [
        _FormSection(
          title: 'Dados gerais',
          subtitle: 'Informações principais do RDC',
          icon: Icons.badge_outlined,
          expanded: _geralExpanded,
          onToggle: () {
            setState(() {
              _geralExpanded = !_geralExpanded;
            });
          },
          child: _ResponsiveFormGrid(
            columns: cols,
            children: [
              _isEditing
                  ? DropdownButtonFormField<int>(
                      isExpanded: true,
                      value: _projetoId,
                      decoration: const InputDecoration(labelText: 'Projeto'),
                      items: _itemsFrom(_projetos),
                      onChanged: (value) {
                        setState(() {
                          _projetoId = value;
                          _sanitizeDependentSelections();
                        });
                      },
                    )
                  : _ReadOnlyField(
                      label: 'Projeto',
                      value: projeto == null
                          ? '-'
                          : '${_displayField(projeto['codigo'])} - ${_displayField(projeto['nome'])}',
                    ),
              _isEditing
                  ? DropdownButtonFormField<int>(
                      isExpanded: true,
                      value: _areaLocalId,
                      decoration: const InputDecoration(
                        labelText: 'Área/local',
                      ),
