class _ResponsiveFormGrid extends StatelessWidget {
  final int columns;
  final List<Widget> children;

  const _ResponsiveFormGrid({required this.columns, required this.children});

  @override
  Widget build(BuildContext context) {
    final screenWidth = MediaQuery.of(context).size.width;
    final spacing = screenWidth < 760 ? 12.0 : 16.0;
    final width = MediaQuery.of(context).size.width;
    final maxContainer = width >= 1180 ? 920.0 : width;
    final usable = maxContainer - (spacing * (columns - 1));
    final itemWidth = usable / columns;

    return Wrap(
      spacing: spacing,
      runSpacing: spacing,
      children: children
          .map(
            (child) =>
                SizedBox(width: itemWidth.clamp(240.0, 450.0), child: child),
          )
          .toList(),
    );
  }
}

