class _RdcDetailPageState extends State<RdcDetailPage> {
  final _updateService = RdcUpdateService();
  final _baseOperacionalService = BaseOperacionalService();

  final _observacoesController = TextEditingController();
  final _horarioInicioController = TextEditingController();
  final _horarioFimController = TextEditingController();
  final _condicaoAreaController = TextEditingController();
  final _climaManhaController = TextEditingController();
  final _climaTardeController = TextEditingController();
  final _climaNoiteController = TextEditingController();
  final _dataController = TextEditingController();
  final _diaSemanaController = TextEditingController();
  final _statusController = TextEditingController();

  bool _isEditing = false;
  bool _isSaving = false;
  bool _initialized = false;

  bool _geralExpanded = true;
  bool _condicoesExpanded = true;
  bool _jornadaExpanded = false;
  bool _observacoesExpanded = true;
  bool _equipesExpanded = false;
  bool _atividadesExpanded = false;
  bool _apontamentosExpanded = false;

  String? _turno;

  int? _projetoId;
  int? _areaLocalId;
  int? _disciplinaId;
  int? _supervisorId;

  List<Map<String, dynamic>> _projetos = const [];
  List<Map<String, dynamic>> _areas = const [];
  List<Map<String, dynamic>> _disciplinas = const [];
  List<Map<String, dynamic>> _funcionarios = const [];

  late Future<RdcDetailResult> _detailFuture;
  late Future<BaseOperacionalResult> _baseFuture;

  @override
  void initState() {
    super.initState();
    _detailFuture = RdcDetailService().getDetail(widget.rdcId);
    _baseFuture = _baseOperacionalService.getBaseOperacional();
  }

  @override
  void dispose() {
    _observacoesController.dispose();
    _horarioInicioController.dispose();
    _horarioFimController.dispose();
    _condicaoAreaController.dispose();
    _climaManhaController.dispose();
    _climaTardeController.dispose();
    _climaNoiteController.dispose();
    _dataController.dispose();
    _diaSemanaController.dispose();
    _statusController.dispose();
    super.dispose();
  }

  String _displayField(dynamic value, {String fallback = '-'}) {
    if (value == null) return fallback;
    final text = value.toString().trim();
    return text.isEmpty ? fallback : text;
  }

  String _displayNested(Map<String, dynamic>? map, List<String> keys) {
    if (map == null) return '-';
    for (final key in keys) {
      final value = map[key];
      if (value != null && value.toString().trim().isNotEmpty) {
        return value.toString().trim();
      }
    }
    return '-';
  }

  String? _emptyToNull(String? value) {
    if (value == null) return null;
    final text = value.trim();
    return text.isEmpty ? null : text;
  }

  bool _isPhone(double width) => width < 700;
  bool _isTablet(double width) => width >= 700 && width < 1100;

  double _pageMaxWidth(double width) {
    if (_isPhone(width)) return width;
    if (_isTablet(width)) return 980;
    return 1360;
  }

  int _fieldColumns(double width) {
    if (_isPhone(width)) return 1;
    if (_isTablet(width)) return 2;
    if (width < 1350) return 3;
    return 4;
  }

  Future<void> _pickDate() async {
    final currentText = _dataController.text.trim();
    DateTime initialDate = DateTime.now();

    if (currentText.isNotEmpty) {
      final parts = currentText.split('-');
      if (parts.length == 3) {
        final year = int.tryParse(parts[0]);
        final month = int.tryParse(parts[1]);
        final day = int.tryParse(parts[2]);
        if (year != null && month != null && day != null) {
          initialDate = DateTime(year, month, day);
        }
      }
    }

    final picked = await showDatePicker(
      context: context,
      initialDate: initialDate,
      firstDate: DateTime(2020),
      lastDate: DateTime(2100),
    );

    if (picked != null) {
      final y = picked.year.toString().padLeft(4, '0');
      final m = picked.month.toString().padLeft(2, '0');
      final d = picked.day.toString().padLeft(2, '0');
      _dataController.text = '$y-$m-$d';
      _syncDiaSemanaFromDate();
      setState(() {});
    }
  }

  Future<void> _pickTime(TextEditingController controller) async {
    TimeOfDay initialTime = const TimeOfDay(hour: 7, minute: 0);

    final currentText = controller.text.trim();
    final parts = currentText.split(':');
    if (parts.length >= 2) {
      final hour = int.tryParse(parts[0]);
      final minute = int.tryParse(parts[1]);
      if (hour != null && minute != null) {
        initialTime = TimeOfDay(hour: hour, minute: minute);
      }
    }

    final picked = await showTimePicker(
      context: context,
      initialTime: initialTime,
    );

    if (picked != null) {
      final h = picked.hour.toString().padLeft(2, '0');
      final m = picked.minute.toString().padLeft(2, '0');
      controller.text = '$h:$m';
      setState(() {});
    }
  }

  void _syncDiaSemanaFromDate() {
    final currentText = _dataController.text.trim();
    final parts = currentText.split('-');
    if (parts.length != 3) return;

    final year = int.tryParse(parts[0]);
    final month = int.tryParse(parts[1]);
    final day = int.tryParse(parts[2]);

    if (year == null || month == null || day == null) return;

    final date = DateTime(year, month, day);
    const dias = [
      'segunda',
      'terça',
      'quarta',
      'quinta',
      'sexta',
      'sábado',
      'domingo',
    ];

    _diaSemanaController.text = dias[date.weekday - 1];
  }

  int? _extractId(dynamic value) {
    if (value == null) return null;
    if (value is int) return value;
    if (value is Map<String, dynamic>) {
      final id = value['id'];
      if (id is int) return id;
      if (id != null) return int.tryParse(id.toString());
    }
    if (value is Map) {
      final map = Map<String, dynamic>.from(value);
      final id = map['id'];
      if (id is int) return id;
      if (id != null) return int.tryParse(id.toString());
    }
    return int.tryParse(value.toString());
  }

  Map<String, dynamic>? _asMap(dynamic value) {
    if (value is Map<String, dynamic>) return value;
    if (value is Map) return Map<String, dynamic>.from(value);
    return null;
  }

  List<Map<String, dynamic>> _asMapList(dynamic value) {
    if (value is List) {
      return value
          .whereType<Map>()
          .map((e) => Map<String, dynamic>.from(e))
          .toList();
    }
    return const [];
  }

  void _fillBase(Map<String, dynamic> raw) {
    _projetos = _asMapList(raw['projetos']);
    _areas = _asMapList(raw['areas']);
    _disciplinas = _asMapList(raw['disciplinas']);
    _funcionarios = _asMapList(raw['funcionarios']);
  }

  void _fillForm(Map<String, dynamic> data) {
    if (_initialized) return;
    _initialized = true;

    _turno = data['turno']?.toString();

    _projetoId = _extractId(data['projeto']);
    _areaLocalId = _extractId(data['area_local']);
    _disciplinaId = _extractId(data['disciplina']);
    _supervisorId = _extractId(data['supervisor']);

    _condicaoAreaController.text = (data['condicao_area'] ?? '').toString();
    _climaManhaController.text = (data['clima_manha'] ?? '').toString();
    _climaTardeController.text = (data['clima_tarde'] ?? '').toString();
    _climaNoiteController.text = (data['clima_noite'] ?? '').toString();
    _horarioInicioController.text = (data['horario_inicio'] ?? '').toString();
    _horarioFimController.text = (data['horario_fim'] ?? '').toString();
    _observacoesController.text = (data['observacoes'] ?? '').toString();
    _dataController.text = (data['data'] ?? '').toString();
    _diaSemanaController.text = (data['dia_semana'] ?? '').toString();
    _statusController.text = (data['status'] ?? '').toString();
  }

  String _optionLabel(Map<String, dynamic> item) {
    final codigo = item['codigo']?.toString().trim() ?? '';
    final nome =
        item['nome']?.toString().trim() ??
        item['descricao']?.toString().trim() ??
        item['username']?.toString().trim() ??
        '';
    if (codigo.isNotEmpty && nome.isNotEmpty) return '$codigo - $nome';
    if (nome.isNotEmpty) return nome;
    if (codigo.isNotEmpty) return codigo;
    return item['id']?.toString() ?? '-';
  }

  List<DropdownMenuItem<int>> _itemsFrom(List<Map<String, dynamic>> source) {
    return source
        .where((item) => item['id'] != null)
        .map(
          (item) => DropdownMenuItem<int>(
            value: _extractId(item['id']),
            child: Text(_optionLabel(item), overflow: TextOverflow.ellipsis),
          ),
        )
        .toList();
  }

  List<Map<String, dynamic>> _filteredAreas() {
    if (_projetoId == null) return _areas;
    final filtered = _areas.where((item) {
      final projeto = item['projeto'];
      final projetoId = item['projeto_id'];
      return _extractId(projeto) == _projetoId ||
          _extractId(projetoId) == _projetoId;
    }).toList();

    return filtered.isEmpty ? _areas : filtered;
  }

  List<Map<String, dynamic>> _filteredSupervisores() {
    if (_disciplinaId == null) return _funcionarios;

    final filtered = _funcionarios.where((item) {
      final disciplina = item['disciplina'];
      final disciplinaId = item['disciplina_id'];
      final funcao = (item['funcao_nome'] ?? '').toString().toLowerCase();
      final cargo = (item['cargo'] ?? '').toString().toLowerCase();

      final matchDisciplina =
          _extractId(disciplina) == _disciplinaId ||
          _extractId(disciplinaId) == _disciplinaId;

      final matchPerfil =
          funcao.contains('supervisor') || cargo.contains('supervisor');

      return matchDisciplina || matchPerfil;
    }).toList();

    return filtered.isEmpty ? _funcionarios : filtered;
  }

  void _sanitizeDependentSelections() {
    final areaIds = _filteredAreas()
        .map((e) => _extractId(e['id']))
        .whereType<int>()
        .toSet();
    final supervisorIds = _filteredSupervisores()
        .map((e) => _extractId(e['id']))
        .whereType<int>()
        .toSet();

    if (_areaLocalId != null && !areaIds.contains(_areaLocalId)) {
      _areaLocalId = null;
    }

    if (_supervisorId != null && !supervisorIds.contains(_supervisorId)) {
      _supervisorId = null;
    }
  }

  Color _statusColor(String status) {
    final value = status.toLowerCase();
    if (value.contains('fech')) return const Color(0xFFB91C1C);
    if (value.contains('valid')) return const Color(0xFF166534);
    if (value.contains('edit')) return const Color(0xFFD97706);
    if (value.contains('abert')) return const Color(0xFF1D4ED8);
    return const Color(0xFF475569);
  }

  IconData _statusIcon(String status) {
    final value = status.toLowerCase();
    if (value.contains('fech')) return Icons.lock_outline;
    if (value.contains('valid')) return Icons.verified_outlined;
    if (value.contains('edit')) return Icons.edit_note;
    if (value.contains('abert')) return Icons.folder_open_outlined;
    return Icons.info_outline;
  }

  Future<void> _save() async {
    FocusScope.of(context).unfocus();

    setState(() {
      _isSaving = true;
    });

    final payload = <String, dynamic>{
      'projeto': _projetoId,
      'area_local': _areaLocalId,
      'disciplina': _disciplinaId,
      'supervisor': _supervisorId,
      'turno': _turno,
      'data': _emptyToNull(_dataController.text),
      'dia_semana': _emptyToNull(_diaSemanaController.text),
      'condicao_area': _emptyToNull(_condicaoAreaController.text),
      'clima_manha': _emptyToNull(_climaManhaController.text),
      'clima_tarde': _emptyToNull(_climaTardeController.text),
      'clima_noite': _emptyToNull(_climaNoiteController.text),
      'horario_inicio': _emptyToNull(_horarioInicioController.text),
      'horario_fim': _emptyToNull(_horarioFimController.text),
      'status': _emptyToNull(_statusController.text),
      'observacoes': _observacoesController.text.trim(),
    };

    final result = await _updateService.updateRdc(
      rdcId: widget.rdcId,
      payload: payload,
    );

    if (!mounted) return;

    setState(() {
      _isSaving = false;
    });

    ScaffoldMessenger.of(
      context,
    ).showSnackBar(SnackBar(content: Text(result.message)));

    if (result.success) {
      setState(() {
        _isEditing = false;
        _initialized = false;
        _detailFuture = RdcDetailService().getDetail(widget.rdcId);
      });
    }
  }

