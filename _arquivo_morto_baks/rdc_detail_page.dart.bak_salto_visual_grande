class _ResponsiveFields extends StatelessWidget {
  final double width;
  final List<Widget> children;

  const _ResponsiveFields({required this.width, required this.children});

  int _columns() {
    if (width < 700) return 1;
    if (width < 1100) return 2;
    if (width < 1350) return 3;
    return 4;
  }

  @override
  Widget build(BuildContext context) {
    final columns = _columns();
    final spacing = width < 700 ? 12.0 : 16.0;
    final itemWidth = (width - (spacing * (columns - 1))) / columns;

    return Wrap(
      spacing: spacing,
      runSpacing: spacing,
      children: children
          .map(
            (child) =>
                SizedBox(width: itemWidth.clamp(220.0, 340.0), child: child),
          )
          .toList(),
    );
  }
}

