  @override
  Widget build(BuildContext context) {
    final screenWidth = MediaQuery.of(context).size.width;
    final maxWidth = _pageMaxWidth(screenWidth);
    final phone = _isPhone(screenWidth);

    return Scaffold(
      appBar: AppBar(title: Text('RDC #${widget.rdcId}')),
      body: SafeArea(
        child: FutureBuilder<List<dynamic>>(
          future: Future.wait([_detailFuture, _baseFuture]),
          builder: (context, snapshot) {
            if (snapshot.connectionState != ConnectionState.done) {
              return const Center(child: CircularProgressIndicator());
            }

            if (!snapshot.hasData || snapshot.data == null) {
              return const Center(
                child: Padding(
                  padding: EdgeInsets.all(24),
                  child: Text(
                    'Não foi possível carregar os dados da tela.',
                    style: TextStyle(color: Colors.redAccent, fontSize: 16),
                  ),
                ),
              );
            }

            final detailResult = snapshot.data![0] as RdcDetailResult;
            final baseResult = snapshot.data![1] as BaseOperacionalResult;

            if (!detailResult.success || detailResult.data == null) {
              return Center(
                child: Padding(
                  padding: const EdgeInsets.all(24),
                  child: Text(
                    detailResult.message,
                    style: const TextStyle(
                      color: Colors.redAccent,
                      fontSize: 16,
                    ),
                  ),
                ),
              );
            }

            if (baseResult.success && baseResult.rawData != null) {
              _fillBase(baseResult.rawData!);
            }

            final data = detailResult.data!;
            _fillForm(data);
            _sanitizeDependentSelections();

            final projeto = _asMap(data['projeto']);
            final disciplina = _asMap(data['disciplina']);
            final areaLocal = _asMap(data['area_local']);
            final supervisor = _asMap(data['supervisor']);

            final funcionarios = _asMapList(
              data['funcionarios'] as List? ?? const [],
            );
            final atividades = _asMapList(
              data['atividades'] as List? ?? const [],
            );
            final apontamentos = _asMapList(
              data['apontamentos'] as List? ?? const [],
            );

            return SingleChildScrollView(
              padding: EdgeInsets.all(phone ? 12 : 20),
              child: Center(
                child: ConstrainedBox(
                  constraints: BoxConstraints(maxWidth: maxWidth),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      _buildExecutiveHeader(
                        width: screenWidth,
                        data: data,
                        projeto: projeto,
                        disciplina: disciplina,
                        areaLocal: areaLocal,
                        supervisor: supervisor,
                        funcionariosCount: funcionarios.length,
                        atividadesCount: atividades.length,
                        apontamentosCount: apontamentos.length,
                      ),
                      const SizedBox(height: 18),
                      _buildActionBar(screenWidth),
                      const SizedBox(height: 18),
                      _buildGeneralSection(
                        screenWidth,
                        projeto,
                        areaLocal,
                        disciplina,
                        supervisor,
                        data,
                      ),
                      const SizedBox(height: 14),
                      _buildConditionsSection(screenWidth, data),
                      const SizedBox(height: 14),
                      _buildJourneySection(screenWidth, data),
                      const SizedBox(height: 14),
                      _buildObservationsSection(screenWidth, data),
                      const SizedBox(height: 14),
                      _ExpandableSection(
                        compact: phone,
                        title: 'Equipe',
                        subtitle: 'Pessoas registradas neste RDC',
                        icon: Icons.groups_outlined,
                        initiallyExpanded: _equipesExpanded,
                        onExpansionChanged: (value) {
                          setState(() {
                            _equipesExpanded = value;
                          });
                        },
                        child: _ListSectionBody(
                          compact: phone,
                          emptyMessage: 'Nenhum funcionário lançado neste RDC.',
                          items: funcionarios,
                          itemBuilder: (item) {
                            final map = Map<String, dynamic>.from(item);
                            return _SimpleListTile(
                              compact: phone,
                              icon: Icons.person_outline,
                              title: _displayField(map['nome']),
                              subtitle: [
                                _displayField(map['matricula'], fallback: ''),
                                _displayField(map['funcao_nome'], fallback: ''),
                              ].where((e) => e.isNotEmpty).join(' • '),
                            );
                          },
                        ),
                      ),
                      const SizedBox(height: 14),
                      _ExpandableSection(
                        compact: phone,
                        title: 'Atividades',
                        subtitle: 'Atividades vinculadas ao RDC',
                        icon: Icons.assignment_outlined,
                        initiallyExpanded: _atividadesExpanded,
                        onExpansionChanged: (value) {
                          setState(() {
                            _atividadesExpanded = value;
                          });
                        },
                        child: _ListSectionBody(
                          compact: phone,
                          emptyMessage: 'Nenhuma atividade lançada neste RDC.',
                          items: atividades,
                          itemBuilder: (item) {
                            final map = Map<String, dynamic>.from(item);
                            return _SimpleListTile(
                              compact: phone,
                              icon: Icons.playlist_add_check_circle_outlined,
                              title: _displayField(map['descricao']),
